{
  "name": "ircv3-mcp",
  "version": "0.1.1",
  "description": "An IRCv3 MCP server: a mini IRC client for agents.",
  "type": "module",
  "license": "MIT",
  "author": "Matheus Fillipe",
  "homepage": "https://github.com/matheusfillipe/ircv3-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/matheusfillipe/ircv3-mcp.git"
  },
  "bin": {
    "ircv3-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs/agent",
    "docs/config.example.toml",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.1.6",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  }
}
